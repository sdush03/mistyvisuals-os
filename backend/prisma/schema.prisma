generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model QuoteGroup {
  id        Int        @id @default(autoincrement())
  leadId    Int        @map("lead_id")
  title     String
  createdAt DateTime   @default(now()) @map("created_at")
  projects  projects[]

  @@map("quote_groups")
}

model QuoteVersion {
  id                 Int         @id @default(autoincrement())
  quoteGroupId       Int         @map("quote_group_id")
  versionNumber      Int         @map("version_number")
  status             QuoteStatus @default(DRAFT)
  calculatedPrice    Decimal?    @map("calculated_price")
  salesOverridePrice Decimal?    @map("sales_override_price")
  overrideReason     String?     @map("override_reason")
  targetPrice        Decimal?    @map("target_price")
  softDiscountPrice  Decimal?    @map("soft_discount_price")
  minimumPrice       Decimal?    @map("minimum_price")
  draftDataJson      Json?       @map("draft_data_json")
  isLatest           Boolean     @default(true) @map("is_latest")
  createdBy          Int?        @map("created_by")
  createdAt          DateTime    @default(now()) @map("created_at")
  projects           projects[]

  @@unique([quoteGroupId, versionNumber], map: "quote_versions_group_version_unique")
  @@index([status])
  @@index([quoteGroupId], map: "quote_versions_group_idx")
  @@map("quote_versions")
}

model QuotePricingItem {
  id             Int             @id @default(autoincrement())
  quoteVersionId Int             @map("quote_version_id")
  itemType       PricingItemType @map("item_type")
  catalogId      Int             @map("catalog_id")
  quantity       Int             @default(1)
  unitPrice      Decimal         @map("unit_price")
  totalPrice     Decimal         @map("total_price")
  phase          String?         @default("WEDDING") @db.VarChar(20)

  @@index([quoteVersionId], map: "quote_pricing_items_version_idx")
  @@map("quote_pricing_items")
}

model TeamRoleCatalog {
  id                Int      @id @default(autoincrement())
  name              String
  price             Decimal
  unitType          UnitType @map("unit_type")
  active            Boolean  @default(true)
  createdAt         DateTime @default(now()) @map("created_at")
  operationalRoleId Int?     @map("operational_role_id")

  @@map("team_role_catalog")
}

model OperationalRole {
  id        Int      @id @default(autoincrement())
  category  String
  name      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("operational_roles")
}

model DeliverableCatalog {
  id               Int                 @id @default(autoincrement())
  name             String
  price            Decimal
  unitType         UnitType            @map("unit_type")
  active           Boolean             @default(true)
  createdAt        DateTime            @default(now()) @map("created_at")
  category         DeliverableCategory @default(OTHER)
  description      String?
  deliveryTimeline String?             @map("delivery_timeline")
  deliveryPhase    String?             @default("WEDDING") @map("delivery_phase") @db.VarChar(20)

  @@map("deliverable_catalog")
}

model PricingRule {
  id                      Int      @id @default(autoincrement())
  ruleName                String   @map("rule_name")
  conditionsJson          Json     @map("conditions_json")
  defaultTeamJson         Json     @map("default_team_json")
  defaultDeliverablesJson Json     @map("default_deliverables_json")
  priority                Int      @default(0)
  active                  Boolean  @default(true)
  createdAt               DateTime @default(now()) @map("created_at")

  @@map("pricing_rules")
}

model QuoteNegotiation {
  id             Int             @id @default(autoincrement())
  quoteVersionId Int             @map("quote_version_id")
  type           NegotiationType
  message        String
  createdBy      Int?            @map("created_by")
  createdAt      DateTime        @default(now()) @map("created_at")

  @@index([quoteVersionId], map: "quote_negotiations_version_idx")
  @@map("quote_negotiations")
}

model QuoteApproval {
  id             Int       @id @default(autoincrement())
  quoteVersionId Int       @map("quote_version_id")
  approvedBy     Int?      @map("approved_by")
  approvedAt     DateTime? @map("approved_at")
  note           String?
  createdAt      DateTime  @default(now()) @map("created_at")

  @@index([quoteVersionId], map: "quote_approvals_version_idx")
  @@map("quote_approvals")
}

model ProposalSnapshot {
  id                       Int        @id @default(autoincrement())
  quoteVersionId           Int        @map("quote_version_id")
  proposalToken            String     @unique @map("proposal_token")
  snapshotJson             Json       @map("snapshot_json")
  createdAt                DateTime   @default(now()) @map("created_at")
  expiresAt                DateTime?  @map("expires_at")
  viewCount                Int        @default(0) @map("view_count")
  lastViewedAt             DateTime?  @map("last_viewed_at")
  total_time_spent_seconds Int        @default(0)
  projects                 projects[]

  @@index([quoteVersionId], map: "proposal_snapshots_version_idx")
  @@map("proposal_snapshots")
}

model ProposalView {
  id                 Int      @id @default(autoincrement())
  proposalSnapshotId Int      @map("proposal_snapshot_id")
  ip                 String?
  device             String?
  createdAt          DateTime @default(now()) @map("created_at")
  duration_seconds   Int      @default(0)

  @@index([createdAt], map: "proposal_views_created_idx")
  @@index([proposalSnapshotId], map: "proposal_views_snapshot_idx")
  @@map("proposal_views")
}

model SystemSettings {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value Json

  @@map("system_settings")
}

model admin_audit_log {
  id         Int       @id @default(autoincrement())
  user_id    Int?
  action     String?
  ip         String?
  metadata   Json?
  created_at DateTime? @default(now()) @db.Timestamptz(6)

  @@index([ip], map: "idx_admin_audit_log_ip")
}

model cities {
  id          Int           @id @default(autoincrement())
  name        String        @db.VarChar(100)
  state_id    Int?
  created_at  DateTime?     @default(now()) @db.Timestamptz(6)
  state       String?       @db.VarChar(100)
  country     String?       @default("India") @db.VarChar(100)
  lead_cities lead_cities[]
}

model compensation_components {
  id                            Int                             @id @default(autoincrement())
  name                          String
  component_type                String                          @default("earning")
  is_variable                   Boolean                         @default(false)
  rule_type                     String?
  calculation_note              String?
  created_at                    DateTime?                       @default(now()) @db.Timestamp(6)
  employee_compensation_entries employee_compensation_entries[]
}

model employee_compensation_entries {
  id                      Int                     @id @default(autoincrement())
  user_id                 Int
  component_id            Int
  amount                  Decimal                 @default(0) @db.Decimal
  month                   DateTime                @db.Date
  lead_id                 Int?
  notes                   String?
  created_at              DateTime?               @default(now()) @db.Timestamp(6)
  compensation_components compensation_components @relation(fields: [component_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users                   users                   @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model employee_compensation_profiles {
  id              Int       @id @default(autoincrement())
  user_id         Int       @unique
  employment_type String    @default("salaried")
  base_amount     Decimal?  @default(0) @db.Decimal
  is_active       Boolean   @default(true)
  created_at      DateTime? @default(now()) @db.Timestamp(6)
  updated_at      DateTime? @default(now()) @db.Timestamp(6)
  users           users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model employee_payouts {
  id                     Int       @id @default(autoincrement())
  user_id                Int
  month                  DateTime  @db.Date
  total_payable          Decimal?  @default(0) @db.Decimal
  total_paid             Decimal?  @default(0) @db.Decimal
  payout_date            DateTime? @db.Date
  finance_transaction_id Int?
  base_salary            Decimal?  @default(0) @db.Decimal
  incentives             Decimal?  @default(0) @db.Decimal
  leave_deduction        Decimal?  @default(0) @db.Decimal
  manual_adjustment      Decimal?  @default(0) @db.Decimal
  carry_forward_prev     Decimal?  @default(0) @db.Decimal
  amount_paid            Decimal?  @default(0) @db.Decimal
  carry_forward_next     Decimal?  @default(0) @db.Decimal
  advance_next           Decimal?  @default(0) @db.Decimal
  created_at             DateTime? @default(now()) @db.Timestamp(6)
  users                  users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, month])
}

model finance_categories {
  id                   Int                    @id @default(autoincrement())
  name                 String
  type                 String
  parent_id            Int?
  created_at           DateTime?              @default(now()) @db.Timestamptz(6)
  updated_at           DateTime?              @default(now()) @db.Timestamp(6)
  finance_transactions finance_transactions[]
}

model finance_transaction_audits {
  id                   Int                  @id @default(autoincrement())
  transaction_id       Int
  field                String
  old_value            String?
  new_value            String?
  edited_by            Int?
  created_at           DateTime             @default(now()) @db.Timestamp(6)
  users                users?               @relation(fields: [edited_by], references: [id], onUpdate: NoAction)
  finance_transactions finance_transactions @relation(fields: [transaction_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([transaction_id], map: "fta_tx_idx")
}

model finance_transactions {
  id                         Int                          @id @default(autoincrement())
  amount                     Decimal                      @default(0) @db.Decimal(12, 2)
  type                       String?
  category_id                Int?
  description                String?
  date                       DateTime?                    @db.Date
  project_id                 Int?
  vendor_id                  Int?
  user_id                    Int?
  metadata                   Json?
  created_at                 DateTime?                    @default(now()) @db.Timestamptz(6)
  project_uuid               String?                      @db.Uuid
  direction                  String?                      @default("out")
  is_deleted                 Boolean                      @default(false)
  is_transfer                Boolean                      @default(false)
  updated_at                 DateTime                     @default(now()) @db.Timestamp(6)
  updated_by                 Int?
  money_source_id            Int?
  lead_id                    Int?
  vendor_bill_id             Int?
  transaction_type           String?
  transfer_group_id          String?
  reference_code             String?
  is_overhead                Boolean?                     @default(false)
  note                       String?
  finance_transaction_audits finance_transaction_audits[]
  finance_categories         finance_categories?          @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  projects                   projects?                    @relation(fields: [project_uuid], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users                      users?                       @relation(fields: [updated_by], references: [id], onUpdate: NoAction)

  @@index([date])
  @@index([date], map: "idx_finance_transactions_date")
}

model GalleryEvent {
  id                     Int      @id @default(autoincrement())
  leadId                 Int?     @map("lead_id")
  slug                   String   @unique @db.VarChar(255)
  title                  String   @db.VarChar(255)
  date                   DateTime @db.Timestamp(6)
  qrToken                String   @unique @map("qr_token") @db.VarChar(255)
  coverPhotoUrl          String?  @map("cover_photo_url") @db.VarChar(1024)
  active                 Boolean  @default(true)
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt              DateTime @default(now()) @map("updated_at") @db.Timestamp(6)
  coverPhotoMobileUrl    String?  @map("cover_photo_mobile_url")
  projectId              String?  @unique @map("project_id")
  tabs                   String[] @default([])
  clustersDirty          Boolean  @default(true) @map("clusters_dirty")
  clustersCache          Json?    @map("clusters_cache")
  coverPhotoSquareUrl    String?  @map("cover_photo_square_url")
  guests                 Guest[]
  photos                 Photo[]

  @@index([qrToken], map: "idx_gallery_events_qr_token")
  @@index([slug], map: "idx_gallery_events_slug")
  @@map("gallery_events")
}

model Guest {
  id              Int          @id @default(autoincrement())
  eventId         Int          @map("event_id")
  email           String       @db.VarChar(255)
  name            String?      @db.VarChar(255)
  phoneNumber     String?      @map("phone_number") @db.VarChar(50)
  provider        String       @default("google") @db.VarChar(50)
  providerId      String       @map("provider_id") @db.VarChar(255)
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamp(6)
  hasFullAccess   Boolean?     @default(false) @map("has_full_access")
  galleryEvent    GalleryEvent @relation(fields: [eventId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  likes           PhotoLike[]

  @@unique([eventId, email])
  @@index([eventId], map: "idx_guests_event_id")
  @@map("guests")
}

model indian_states {
  id      Int    @id @default(autoincrement())
  name    String @unique
  country String @default("India")
}

model invoice_line_items {
  id                  Int       @id @default(autoincrement())
  invoice_id          Int?
  description         String?
  amount              Decimal?  @db.Decimal(12, 2)
  quantity            Int?      @default(1)
  unit_price          Decimal?  @default(0) @db.Decimal
  line_total          Decimal?  @default(0) @db.Decimal
  is_billable_expense Boolean?  @default(false)
  vendor_bill_id      Int?
  invoices            invoices? @relation(fields: [invoice_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model invoice_payment_schedule {
  id         Int       @id @default(autoincrement())
  invoice_id Int?
  due_date   DateTime? @db.Date
  amount     Decimal?  @db.Decimal(12, 2)
  status     String?   @default("pending")
  label      String?
  percentage Decimal?  @db.Decimal
  step_order Int?      @default(1)
  invoices   invoices? @relation(fields: [invoice_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model invoice_payments {
  id                     Int       @id @default(autoincrement())
  invoice_id             Int?
  amount                 Decimal?  @db.Decimal(12, 2)
  paid_at                DateTime? @default(now()) @db.Timestamptz(6)
  method                 String?
  note                   String?
  amount_applied         Decimal?  @db.Decimal
  finance_transaction_id Int?
  created_at             DateTime? @default(now()) @db.Timestamp(6)
  invoices               invoices? @relation(fields: [invoice_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model invoices {
  id                                     Int                        @id @default(autoincrement())
  lead_id                                Int?
  quote_group_id                         Int?
  total_amount                           Decimal?                   @db.Decimal(12, 2)
  status                                 String?                    @default("draft")
  metadata                               Json?
  created_at                             DateTime?                  @default(now()) @db.Timestamptz(6)
  project_id                             String?                    @db.Uuid
  advance_amount                         Decimal?                   @default(0) @db.Decimal(12, 2)
  balance_amount                         Decimal?                   @default(0) @db.Decimal(12, 2)
  advance_paid                           Boolean?                   @default(false)
  due_date                               DateTime?                  @db.Date
  invoice_number                         String?
  invoice_type                           String?                    @default("non_gst")
  payment_structure_id                   Int?
  subtotal                               Decimal?                   @default(0) @db.Decimal
  tax_amount                             Decimal?                   @default(0) @db.Decimal
  issue_date                             DateTime?                  @db.Date
  notes                                  String?
  updated_at                             DateTime?                  @default(now()) @db.Timestamp(6)
  share_token                            String?                    @unique(map: "invoices_share_token_idx") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  is_verified                            Boolean?                   @default(false)
  invoice_line_items                     invoice_line_items[]
  invoice_payment_schedule               invoice_payment_schedule[]
  invoice_payments                       invoice_payments[]
  leads                                  leads?                     @relation(fields: [lead_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  projects_invoices_project_idToprojects projects?                  @relation("invoices_project_idToprojects", fields: [project_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  projects_projects_invoice_idToinvoices projects[]                 @relation("projects_invoice_idToinvoices")
}

model known_internal_ips {
  ip           String    @id
  last_seen_at DateTime? @default(now()) @db.Timestamptz(6)
}

model lead_activities {
  id            Int       @id @default(autoincrement())
  lead_id       Int?
  activity_type String
  metadata      Json?
  created_at    DateTime? @default(now()) @db.Timestamp(6)
  user_id       Int?
  leads         leads?    @relation(fields: [lead_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users         users?    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([lead_id, created_at], map: "idx_lead_activities_lead_id_created_at")
  @@index([activity_type, created_at], map: "idx_lead_activities_type_created_at")
}

model lead_cities {
  id         Int       @id @default(autoincrement())
  lead_id    Int
  city_id    Int
  is_primary Boolean?  @default(false)
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  cities     cities    @relation(fields: [city_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  leads      leads     @relation(fields: [lead_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([lead_id, city_id])
  @@index([lead_id], map: "idx_lead_cities_lead_id")
}

model lead_enrichment_logs {
  id         Int      @id @default(autoincrement())
  lead_id    Int
  payload    Json?
  user_id    Int?
  created_at DateTime @default(now()) @db.Timestamptz(6)
  leads      leads    @relation(fields: [lead_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users      users?   @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([lead_id], map: "idx_lead_enrichment_logs_lead_id")
}

model lead_events {
  id             Int              @id @default(autoincrement())
  lead_id        Int
  event_type     String?          @db.VarChar(100)
  event_date     DateTime?        @db.Date
  pax            Int?
  venue          String?          @db.VarChar(200)
  description    String?
  start_time     String?          @db.VarChar(10)
  end_time       String?          @db.VarChar(10)
  slot           String?          @db.VarChar(50)
  city_id        Int?
  venue_id       String?
  venue_metadata Json?
  date_status    String?          @default("confirmed") @db.VarChar(20)
  position       Int?             @default(1)
  created_at     DateTime?        @default(now()) @db.Timestamptz(6)
  updated_at     DateTime?        @default(now()) @db.Timestamptz(6)
  leads          leads            @relation(fields: [lead_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  project_events project_events[]

  @@index([lead_id], map: "idx_lead_events_lead_id")
}

model lead_followups {
  id                   Int      @id @default(autoincrement())
  lead_id              Int
  follow_up_at         DateTime @db.Timestamptz(6)
  type                 String
  note                 String?
  outcome              String?
  follow_up_mode       String?
  discussed_topics     Json?
  not_connected_reason String?
  user_id              Int?
  created_at           DateTime @default(now()) @db.Timestamptz(6)
  leads                leads    @relation(fields: [lead_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users                users?   @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([lead_id, follow_up_at], map: "idx_lead_followups_lead_id_follow_up_at")
}

model lead_lost_reasons {
  id      Int       @id @default(autoincrement())
  lead_id Int       @unique
  reason  String
  note    String?
  user_id Int?
  lost_at DateTime? @default(now()) @db.Timestamptz(6)
  leads   leads     @relation(fields: [lead_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model lead_metrics {
  lead_id                    Int       @id
  total_followups            Int       @default(0)
  connected_followups        Int       @default(0)
  not_connected_count        Int       @default(0)
  avg_days_between_followups Decimal?  @db.Decimal
  total_time_spent_seconds   Int       @default(0)
  last_activity_at           DateTime? @db.Timestamp(6)
  days_to_first_contact      Decimal?  @db.Decimal
  days_to_conversion         Decimal?  @db.Decimal
  reopen_count               Int       @default(0)
  leads                      leads     @relation(fields: [lead_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model lead_negotiations {
  id         Int      @id @default(autoincrement())
  lead_id    Int
  topic      String
  note       String
  user_id    Int?
  created_at DateTime @default(now()) @db.Timestamptz(6)
  leads      leads    @relation(fields: [lead_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users      users?   @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([lead_id], map: "idx_lead_negotiations_lead_id")
}

model lead_notes {
  id             Int       @id @default(autoincrement())
  lead_id        Int
  note_text      String
  created_at     DateTime? @default(now()) @db.Timestamp(6)
  status_at_time String?
  user_id        Int?
  leads          leads     @relation(fields: [lead_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users          users?    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([lead_id, created_at], map: "idx_lead_notes_lead_id_created_at")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model lead_pricing_logs {
  id         Int       @id @default(autoincrement())
  lead_id    Int?
  field_type String?
  amount     Decimal   @db.Decimal
  created_at DateTime? @default(now()) @db.Timestamp(6)
  user_id    Int?
  leads      leads?    @relation(fields: [lead_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users      users?    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([lead_id], map: "idx_lead_pricing_logs_lead_id")
}

model lead_quotes {
  id                Int       @id @default(autoincrement())
  lead_id           Int?
  quote_number      String
  generated_text    String
  amount_quoted     Decimal?  @db.Decimal
  discounted_amount Decimal?  @db.Decimal
  created_at        DateTime? @default(now()) @db.Timestamp(6)
  created_by        Int?
  users             users?    @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  leads             leads?    @relation(fields: [lead_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([lead_id], map: "idx_lead_quotes_lead_id")
}

model lead_usage_logs {
  id               Int       @id @default(autoincrement())
  user_id          Int
  lead_id          Int
  entered_at       DateTime  @default(now()) @db.Timestamp(6)
  left_at          DateTime? @db.Timestamp(6)
  duration_seconds Int?
  leads            leads     @relation(fields: [lead_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users            users     @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([lead_id], map: "idx_lead_usage_logs_lead_id")
  @@index([user_id], map: "idx_lead_usage_logs_user_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model leads {
  id                       Int                    @id @default(autoincrement())
  name                     String
  source                   String
  status                   String                 @default("New")
  created_at               DateTime?              @default(now()) @db.Timestamp(6)
  previous_status          String?
  updated_at               DateTime?              @default(now()) @db.Timestamp(6)
  heat                     String?                @default("Cold")
  event_type               String?                @default("Wedding")
  is_destination           Boolean?               @default(false)
  country                  String?                @default("India")
  phone_primary            String
  phone_secondary          String?
  email                    String?
  bride_name               String?
