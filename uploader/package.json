{
  "name": "misty-visuals-uploader",
  "version": "1.0.0",
  "description": "Misty Visuals Desktop AI Photo Gallery Uploader",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "exifr": "^7.1.3",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.mistyvisuals.uploader",
    "productName": "Misty Visuals Uploader",
    "mac": {
      "category": "public.app-category.photography-video"
    },
    "protocols": {
      "name": "mistyuploader-protocol",
      "schemes": [
        "mistyuploader"
      ]
    }
  }
}
