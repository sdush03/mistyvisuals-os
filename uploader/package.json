{
  "name": "misty-visuals-gallery-uploader",
  "version": "1.1.1",
  "description": "Misty Visuals Desktop AI Photo Gallery Uploader",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win --x64"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "exifr": "^7.1.3",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.mistyvisuals.uploader",
    "productName": "Misty Visuals Gallery Uploader",
    "asar": true,
    "asarUnpack": [
      "**/node_modules/sharp/**/*",
      "**/node_modules/@img/**/*"
    ],
    "extraResources": [
      {
        "from": "../backend/utils/face_rec.py",
        "to": "face_rec.py"
      },
      {
        "from": "../backend/models",
        "to": "models"
      }
    ],
    "mac": {
      "category": "public.app-category.photography-video",
      "target": [
        "dmg",
        "pkg"
      ]
    },
    "pkg": {
      "installLocation": "/Applications"
    },
    "protocols": {
      "name": "mistyuploader-protocol",
      "schemes": [
        "mistyuploader"
      ]
    }
  }
}
